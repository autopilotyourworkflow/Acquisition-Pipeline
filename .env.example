# ===========================================================================
# Acquisition Pipeline — environment variables
# ===========================================================================
# 1. Copy this file to `.env.local` (which is gitignored).
# 2. Fill in the values below.
# 3. NEVER paste real secret values into this file or commit them anywhere.
# 4. Production values live ONLY in the Vercel dashboard's env-vars UI.
#
# Generate the two app secrets with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Run that twice — once for OAUTH_ENCRYPTION_SECRET, once for EXTENSION_JWT_SECRET.
# ===========================================================================

# --- Anthropic (Claude) ----------------------------------------------------
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# --- Supabase --------------------------------------------------------------
# Get from: Supabase Dashboard -> Project Settings -> API
# NEXT_PUBLIC_* values are exposed to the browser — safe by design.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SERVER-ONLY. Never expose. Bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=

# --- Google OAuth (for Calendar + Gmail incremental consent) --------------
# Created in Google Cloud Console -> APIs & Services -> Credentials.
# Walkthrough deferred until we wire up the integrations page.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- App-level secrets (we generate these locally — see header) -----------
# Used to encrypt stored Google refresh tokens in Postgres via pgcrypto.
OAUTH_ENCRYPTION_SECRET=
# Signs long-lived JWTs issued to the Chrome companion extension.
EXTENSION_JWT_SECRET=

# --- Optional: third-party scraping API (fallback #3) ----------------------
# Get from: https://nubela.co/proxycurl (or Apify). Add only if you want
# the "Third-party API" tab in the Scraper module to work.
PROXYCURL_API_KEY=

# --- App base URL ----------------------------------------------------------
# For local dev this stays http://localhost:3000.
# In Vercel production set to https://acq.autopilotyourworkflow.com
NEXT_PUBLIC_APP_URL=http://localhost:3000
